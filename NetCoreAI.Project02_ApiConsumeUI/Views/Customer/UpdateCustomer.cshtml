@model UpdateCustomerViewModel

@{
    Layout = null;
}
<link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />

<form method="post" asp-action="UpdateCustomer" asp-route-id="@Model.CustomerID">
    <div class="container">
        <br />
        <br />
        <label>Müşteri Adı</label>
        <input type="text" asp-for="CustomerName" class="form-control" />
        <br />
        <label>Müşteri Soyadı</label>
        <input type="text" asp-for="CustomerSurname" class="form-control" />
        <br />
        <label>Müşteri Bakiye</label>
        <input type="text" asp-for="CustomerBalance" class="form-control" />
        <br />
        <button class="btn btn-primary">Müşteri Güncelle</button>
    </div>
</form>